<?xml version="1.0" encoding="utf-8"?>
<!-- DebtStatusWidget: 1x1 — Shows debt utilization ring + total debt -->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/widget_bg_deep"
    android:padding="12dp">

    <!-- Header -->
    <TextView
        android:id="@+id/widget_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:text="💳 BORÇ DURUMU"
        android:textColor="@color/widget_text_tertiary"
        android:textSize="9sp"
        android:textStyle="bold"
        android:letterSpacing="0.1" />

    <!-- Center: utilization percentage (large) -->
    <LinearLayout
        android:id="@+id/widget_center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:orientation="vertical">

        <ProgressBar
            android:id="@+id/widget_progress"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="72dp"
            android:layout_height="8dp"
            android:layout_marginBottom="8dp"
            android:max="100"
            android:progressDrawable="@android:drawable/progress_horizontal" />

        <TextView
            android:id="@+id/widget_percent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="%30"
            android:textColor="@color/widget_green"
            android:textSize="28sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Bottom: total debt -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₺15.0B"
            android:textColor="@color/widget_text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Toplam Borç"
            android:textColor="@color/widget_text_tertiary"
            android:textSize="10sp" />
    </LinearLayout>
</RelativeLayout>
