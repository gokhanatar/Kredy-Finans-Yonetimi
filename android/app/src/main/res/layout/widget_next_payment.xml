<?xml version="1.0" encoding="utf-8"?>
<!-- NextPaymentWidget: 2x1 — Shows upcoming card payment with countdown -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/widget_bg_deep"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Header -->
    <TextView
        android:id="@+id/widget_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📅 SONRAKİ ÖDEME"
        android:textColor="@color/widget_text_tertiary"
        android:textSize="9sp"
        android:textStyle="bold"
        android:letterSpacing="0.1" />

    <!-- Content row: card info + days -->
    <LinearLayout
        android:id="@+id/widget_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <!-- Left: card info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingEnd="12dp">

            <TextView
                android:id="@+id/widget_bank_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💳 Akbank"
                android:textColor="@color/widget_text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/widget_card_digits"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="•••• 1234"
                android:textColor="@color/widget_text_secondary"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/widget_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₺15,000"
                android:textColor="@color/widget_text_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="6dp" />
        </LinearLayout>

        <!-- Right: days countdown -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:background="@color/widget_bg_elevated"
            android:padding="12dp"
            android:minWidth="64dp">

            <TextView
                android:id="@+id/widget_days"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="15"
                android:textColor="@color/widget_text_primary"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="gün"
                android:textColor="@color/widget_text_secondary"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/widget_urgency"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rahat"
                android:textColor="@color/widget_green"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Empty state (hidden by default) -->
    <TextView
        android:id="@+id/widget_empty"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="✓ Yaklaşan ödeme yok"
        android:textColor="@color/widget_text_secondary"
        android:textSize="13sp"
        android:visibility="gone" />
</LinearLayout>
