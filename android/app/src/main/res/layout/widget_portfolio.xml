<?xml version="1.0" encoding="utf-8"?>
<!-- PortfolioWidget: 1x1 — Shows portfolio value + P&L -->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/widget_bg_deep"
    android:padding="12dp">

    <!-- Header -->
    <TextView
        android:id="@+id/widget_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:text="📈 PORTFÖY"
        android:textColor="@color/widget_text_tertiary"
        android:textSize="9sp"
        android:textStyle="bold"
        android:letterSpacing="0.1" />

    <!-- Center: portfolio value -->
    <LinearLayout
        android:id="@+id/widget_center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₺125,000"
            android:textColor="@color/widget_text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_pnl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="↗ +25.0%"
            android:textColor="@color/widget_green"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- Bottom label -->
    <TextView
        android:id="@+id/widget_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:text="Toplam Yatırım"
        android:textColor="@color/widget_text_tertiary"
        android:textSize="10sp" />

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/widget_empty"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📈"
            android:textSize="28sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Yatırım Ekle"
            android:textColor="@color/widget_text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="4dp" />
    </LinearLayout>
</RelativeLayout>
