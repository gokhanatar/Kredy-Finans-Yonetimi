<?xml version="1.0" encoding="utf-8"?>
<!-- SavingsGoalWidget: 2x1 — Shows savings goal progress -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/widget_bg_deep"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Header -->
    <TextView
        android:id="@+id/widget_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎯 BİRİKİM HEDEFİ"
        android:textColor="@color/widget_text_tertiary"
        android:textSize="9sp"
        android:textStyle="bold"
        android:letterSpacing="0.1" />

    <!-- Content -->
    <LinearLayout
        android:id="@+id/widget_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginTop="6dp">

        <!-- Left: percentage circle substitute -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingEnd="16dp">

            <TextView
                android:id="@+id/widget_percent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="%65"
                android:textColor="@color/widget_blue"
                android:textSize="28sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Right: goal details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_goal_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎯 Tatil Fonu"
                android:textColor="@color/widget_text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/widget_current"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₺32,500"
                android:textColor="@color/widget_text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />

            <ProgressBar
                android:id="@+id/widget_progress"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_marginTop="6dp"
                android:max="100"
                android:progressDrawable="@android:drawable/progress_horizontal" />

            <TextView
                android:id="@+id/widget_target"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hedef: ₺50,000"
                android:textColor="@color/widget_text_tertiary"
                android:textSize="10sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Empty state -->
    <TextView
        android:id="@+id/widget_empty"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="🎯\nHedef ekleyin"
        android:textColor="@color/widget_text_secondary"
        android:textSize="13sp"
        android:visibility="gone" />
</LinearLayout>
